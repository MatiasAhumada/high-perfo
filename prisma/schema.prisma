generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  COACH
}

enum RoutineStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum AssessmentType {
  NEUROMUSCULAR
  ANTHROPOMETRY
  VBT
  ASYMMETRY
}

enum ToolKey {
  TEJIDO_BLANDO
  PLIOMETRIA
  MOVILIDAD
  CLIMA
  GPS
  ASIMETRIA
}

enum WeekType {
  MAINTENANCE
  SPORT_SPECIFIC
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SportType {
  RUGBY
  FUTBOL
  BASQUET
  TENIS
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  maxCoaches      Int      @default(1)
  maxAthletes     Int      @default(10)
  maxAssessments  Int      @default(100)
  price           Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts Account[]
}

model Account {
  id             String   @id @default(uuid())
  name           String
  isOrganization Boolean  @default(true)
  planId         String
  plan           Plan     @relation(fields: [planId], references: [id])

  users             User[]
  athletes          Athlete[]
  templates         RoutineTemplate[]
  exercises         ExerciseLibrary[]
  toolTemplates     ToolTemplate[]
  designConfig      DesignConfig?
  metricDefinitions MetricDefinition[]
  trainingWeeks     TrainingWeek[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     Role   @default(COACH)
  isActive Boolean @default(true)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  createdTemplates     RoutineTemplate[]
  createdExercises     ExerciseLibrary[]
  createdToolTemplates ToolTemplate[]
  assessmentsPerformed Assessment[]
  assignedRoutines     AssignedRoutine[]
  createdWeeks         TrainingWeek[]
  trainingSessions     TrainingSession[]

  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId])
}

model DesignConfig {
  id            String  @id @default(uuid())
  accountId     String  @unique
  account       Account @relation(fields: [accountId], references: [id])

  primaryColor   String @default("#ef233c")
  surfaceColor   String @default("#101417")
  surfaceVariant String @default("#1d2023")
  textColor      String @default("#e0e2e6")

  fontFamilyHead String @default("Space Grotesk")
  fontFamilyBody String @default("Manrope")
  borderRadius   String @default("0.25rem")

  updatedAt DateTime @updatedAt
}

model Athlete {
  id        String    @id @default(uuid())
  firstName String
  lastName  String
  puesto    String?
  birthDate DateTime?
  sport     SportType?

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  assessments      Assessment[]
  assignedRoutines AssignedRoutine[]
  trainingWeeks    TrainingWeek[]

  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId])
  @@index([sport])
}

model Assessment {
  id        String @id @default(uuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id])

  coachId String
  coach   User @relation(fields: [coachId], references: [id])

  date       DateTime       @default(now())
  type       AssessmentType
  bodyWeight Float?

  results MetricResult[]

  @@index([athleteId])
}

model MetricResult {
  id             String     @id @default(uuid())
  assessmentId   String
  assessment     Assessment @relation(fields: [assessmentId], references: [id])

  key             String
  rawValue        Float
  calculatedValue Float?

  createdAt DateTime @default(now())

  @@index([assessmentId])
}

model RoutineTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?
  isGlobal    Boolean @default(false)

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  creatorId String
  creator   User @relation(fields: [creatorId], references: [id])

  exercises TemplateExercise[]
  assignedRoutines AssignedRoutine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([isGlobal])
}

model TemplateExercise {
  id               String          @id @default(uuid())
  templateId       String
  template         RoutineTemplate @relation(fields: [templateId], references: [id])

  name             String
  order            Int
  sets             Int
  reps             Int
  intensityPercent Float?

  createdAt DateTime @default(now())
}

model AssignedRoutine {
  id String @id @default(uuid())
  athleteId String
  athlete Athlete @relation(fields: [athleteId], references: [id])

  coachId String
  coach User @relation(fields: [coachId], references: [id])

  templateId String?
  template RoutineTemplate? @relation(fields: [templateId], references: [id])

  startDate DateTime
  endDate DateTime?
  status RoutineStatus @default(ACTIVE)

  toolExecutions ToolExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([athleteId, status])
}

model ToolExecution {
  id                String          @id @default(uuid())
  assignedRoutineId String
  routine           AssignedRoutine @relation(fields: [assignedRoutineId], references: [id])

  toolKey   ToolKey
  completed Boolean  @default(false)
  data      Json?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model MetricDefinition {
  id        String  @id @default(uuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  key             String
  label           String
  unit            String
  redZoneLimit    Float?
  greenZoneLimit  Float?

  @@unique([accountId, key])
}

model ExerciseLibrary {
  id          String  @id @default(uuid())
  name        String
  description String?
  category    String?
  muscleGroup String?
  equipment   String?
  videoUrl    String?
  toolKey     ToolKey?
  sport       SportType?
  isGlobal    Boolean @default(false)
  
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  creatorId String
  creator   User @relation(fields: [creatorId], references: [id])

  sessionExercises     SessionExercise[]
  toolTemplateExercises ToolTemplateExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([toolKey])
  @@index([sport])
  @@index([isGlobal])
}

model TrainingWeek {
  id          String   @id @default(uuid())
  name        String
  description String?
  weekType    WeekType @default(MAINTENANCE)
  sport       SportType?
  weekNumber  Int?
  isClosed    Boolean  @default(false)
  isTemplate  Boolean  @default(false)
  
  athleteId String?
  athlete   Athlete? @relation(fields: [athleteId], references: [id])
  
  coachId String
  coach   User @relation(fields: [coachId], references: [id])
  
  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  sessions TrainingSession[]

  startDate DateTime
  endDate   DateTime?
  closedAt  DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([athleteId])
  @@index([weekType])
  @@index([isTemplate])
  @@index([sport])
}

model TrainingSession {
  id          String        @id @default(uuid())
  dayNumber   Int
  sessionName String?
  notes       String?
  status      SessionStatus @default(PENDING)
  
  weekId String
  week   TrainingWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  
  coachId String
  coach   User @relation(fields: [coachId], references: [id])

  exercises SessionExercise[]

  sessionDate  DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([weekId])
  @@index([status])
}

model SessionExercise {
  id       String  @id @default(uuid())
  order    Int
  sets     Int
  reps     Int
  weight   Float?
  rest     Int?
  notes    String?
  
  sessionId String
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  exerciseId String?
  exercise   ExerciseLibrary? @relation(fields: [exerciseId], references: [id])
  
  customExerciseName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([exerciseId])
}

model ToolTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?
  toolKey     ToolKey
  isGlobal    Boolean @default(false)
  
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  creatorId String
  creator   User @relation(fields: [creatorId], references: [id])

  exercises ToolTemplateExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([toolKey])
  @@index([isGlobal])
}

model ToolTemplateExercise {
  id               String       @id @default(uuid())
  toolTemplateId   String
  toolTemplate     ToolTemplate @relation(fields: [toolTemplateId], references: [id], onDelete: Cascade)

  exerciseId String?
  exercise   ExerciseLibrary? @relation(fields: [exerciseId], references: [id])

  customExerciseName String?
  order              Int
  sets               Int?
  reps               Int?
  duration           Int?
  rest               Int?
  notes              String?

  createdAt DateTime @default(now())

  @@index([toolTemplateId])
  @@index([exerciseId])
}
